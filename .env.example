# ──────────────────────────────────────────────────────────
# .env.example — Vibe Architect v3.0
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────

# ── LLM Provider (pick one) ────────────────────────────────
LLM_PROVIDER=groq                      # groq | ollama | openai | anthropic

# Groq (recommended — fast, free tier, no GPU needed)
GROQ_API_KEY=gsk_...                   # from console.groq.com
GROQ_MODEL=llama-3.1-70b-versatile

# Ollama (self-hosted, zero cost)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# OpenAI (fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (highest quality)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Session Storage ────────────────────────────────────────
SESSION_BACKEND=redis
REDIS_URL=redis://redis:6379
SESSION_TTL_HOURS=24

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_SESSIONS_PER_IP_PER_HOUR=3
RATE_LIMIT_MAX_ACTIVE_SESSIONS_PER_IP=1

# ── Cost Controls ──────────────────────────────────────────
MAX_CONVERSATION_TOKENS=6000
DAILY_COST_ALERT_USD=10.00
ENABLE_COST_TRACKING=true

# ── App ────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ── Feature Flags ──────────────────────────────────────────
ENABLE_PREVIEW_ENGINE=true
ENABLE_OLLAMA_FALLBACK=false

# ── NLP Layer (v3.0) ───────────────────────────────────────
ENABLE_NLP_LAYER=true              # false = disable all NLP, use v2.0 regex
MODEL_CACHE_DIR=/models            # Docker volume mount point

# Model overrides (swap to lighter models if needed)
NLP_CLASSIFIER_MODEL=distilbert-base-uncased-finetuned-sst-2-english
NLP_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
NLP_DOMAIN_MODEL=valhalla/distilbart-mnli-12-1
NLP_SIMILARITY_MODEL=all-MiniLM-L6-v2

# NLP Thresholds (tune without code changes)
NLP_QUALITY_SUBSTANCE_THRESHOLD=0.80
NLP_DOMAIN_CONFIDENCE_THRESHOLD=0.40
NLP_DEDUP_SIMILARITY_THRESHOLD=0.85
NLP_EXPERTISE_PROBE_THRESHOLD=0.70

# ── Emergent Platform (v3.0) ───────────────────────────────
EMERGENT_PROMPT_MAX_TOKENS=6000

# ── Build Config ────────────────────────────────────────────
BUILD_DOWNLOAD_MODELS=true         # false to skip model download in Docker build
